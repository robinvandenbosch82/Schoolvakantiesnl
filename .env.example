# Copy to .env and fill in. NEVER commit the real .env.
# Generate a key: python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
SITE_DOMAIN=schoolvakanties.nl
# Canonical origin for structured-data @id's + canonical URLs (default https://{SITE_DOMAIN}).
SITE_ORIGIN=https://www.schoolvakanties.nl

# Image / content tooling (optional in dev)
PEXELS_API_KEY=
ANTHROPIC_API_KEY=

# E-mail — leeg in dev (console-backend print mails in de log). In productie de
# SMTP-gegevens invullen, anders worden samenwerking-leads alleen in de DB
# opgeslagen en niet doorgemaild (leads gaan dus nooit verloren).
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=no-reply@schoolvakanties.nl
# PARTNER_INBOX=partners@schoolvakanties.nl

# Security headers (CSP staat standaard aan; report-only om te testen):
# CSP_ENABLED=True
# CSP_REPORT_ONLY=False

# Error tracking (optioneel; zonder DSN gebeurt er niets):
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.0
# SENTRY_ENVIRONMENT=production

# Production database (uncomment in prod):
# DATABASE_URL=postgres://user:pass@host:5432/dbname
